# ============================================================
# FlowLynk — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Django Core
# ------------------------------------------------------------
# Settings module: webcrm.settings.dev | webcrm.settings.prod
DJANGO_SETTINGS_MODULE=webcrm.settings.dev

# Secret key — MUST be unique and unpredictable in production.
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Debug mode — always False in production.
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames.
# Dev default covers lvh.me subdomains. Prod requires explicit domains.
DJANGO_ALLOWED_HOSTS=.lvh.me,localhost,127.0.0.1

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_DB=flowlynk
POSTGRES_USER=flowlynk
POSTGRES_PASSWORD=flowlynk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Platform / Tenancy
# ------------------------------------------------------------
# Base domain for public landing and login.
# Tenant subdomains resolve as {org_slug}.{PLATFORM_BASE_DOMAIN}
# Dev: lvh.me (resolves to 127.0.0.1, supports subdomains)
# Prod: your actual domain (e.g., flowlynk.com)
PLATFORM_BASE_DOMAIN=lvh.me

# Port appended to URLs in dev. Leave empty for production (443).
PLATFORM_PORT=8000

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------
# Dev: console backend prints to stdout.
# Prod: replace with SMTP or transactional provider.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ------------------------------------------------------------
# Static / Media Files
# ------------------------------------------------------------
# Prod only — path where collectstatic writes files.
# STATIC_ROOT=/var/www/flowlynk/static

# Object storage for tenant attachments (Phase 2+).
# MEDIA_ROOT=/var/www/flowlynk/media
# DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# Background Jobs (Phase 2+)
# ------------------------------------------------------------
# Celery / RQ broker URL.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
# Sentry DSN for error tracking (prod).
# SENTRY_DSN=

# Log level override: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# ------------------------------------------------------------
# Security (production only)
# ------------------------------------------------------------
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
